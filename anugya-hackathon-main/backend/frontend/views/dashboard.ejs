<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | ANUGYA</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap');
        body { font-family: 'Inter', sans-serif; }
        .stat-card {
            background: #111;
            border: 1px solid #333;
            transition: all 0.3s ease;
        }
        .stat-card:hover {
            border-color: #8F00FF;
            transform: translateY(-5px);
        }
    </style>
    <!-- ADD THIS CODE ONLY -->
    <script
      async
      crossorigin="anonymous"
      data-clerk-publishable-key="<%= process.env.NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY %>"
      src="https://enabling-donkey-93.clerk.accounts.dev/npm/@clerk/clerk-js@latest/dist/clerk.browser.js"
      type="text/javascript"
    ></script>
    <!-- DO NOT MODIFY EXISTING CODE -->
</head>
<body class="bg-black text-white min-h-screen">
    <!-- Header -->
    <header class="p-6 border-b border-gray-800 flex justify-between items-center">
        <div class="flex items-center gap-4">
            <a href="/" class="text-gray-400 hover:text-white transition-colors">
                <i class="fas fa-arrow-left"></i>
            </a>
            <h1 class="text-2xl font-bold bg-gradient-to-r from-purple-400 to-green-400 bg-clip-text text-transparent">
                YOUR DASHBOARD
            </h1>
        </div>
        <div class="flex items-center gap-3">
            <button id="add-account-btn" style="background: white; color: black; padding: 8px 16px; border-radius: 20px; font-weight: bold; cursor: pointer; font-size: 14px; margin-right: 10px;">Sign In</button>
            <!-- ADD THIS CODE ONLY -->
            <div id="user-button"></div>
            <span id="user-name" class="font-medium">Loading...</span>

            <script>
                window.addEventListener('load', async function () {
                    await window.Clerk.load();
                    
                    const addAccountBtn = document.getElementById('add-account-btn');
                    if(addAccountBtn) {
                        addAccountBtn.onclick = () => window.Clerk.openSignIn();
                    }

                    if (window.Clerk.user) {
                        window.Clerk.mountUserButton(document.getElementById('user-button'));
                        document.getElementById('user-name').innerText = window.Clerk.user.fullName || window.Clerk.user.firstName || 'User';
                    } else {
                        window.location.href = '/';
                    }
                });
            </script>
            <!-- DO NOT MODIFY EXISTING CODE -->
        </div>
    </header>

    <main class="max-w-6xl mx-auto p-6">
        <!-- Stats Grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
            <div class="stat-card p-6 rounded-2xl">
                <div class="flex justify-between items-start mb-4">
                    <div class="w-12 h-12 rounded-xl bg-purple-900/30 flex items-center justify-center text-purple-400">
                        <i class="fas fa-barcode"></i>
                    </div>
                    <span class="text-xs text-gray-500">Total Scans</span>
                </div>
                <div class="text-3xl font-bold"><%= stats ? stats.totalScans : 0 %></div>
                <div class="text-sm text-gray-400 mt-2">
                    Scans performed over time
                </div>
            </div>

            <div class="stat-card p-6 rounded-2xl">
                <div class="flex justify-between items-start mb-4">
                    <div class="w-12 h-12 rounded-xl bg-green-900/30 flex items-center justify-center text-green-400">
                        <i class="fas fa-shield-heart"></i>
                    </div>
                    <span class="text-xs text-gray-500">Safety Score</span>
                </div>
                <div class="text-3xl font-bold"><%= stats ? stats.avgSafetyScore : 0 %>/10</div>
                <div class="text-sm text-gray-400 mt-2">
                    Based on your scan history
                </div>
            </div>

            <div class="stat-card p-6 rounded-2xl">
                <div class="flex justify-between items-start mb-4">
                    <div class="w-12 h-12 rounded-xl bg-blue-900/30 flex items-center justify-center text-blue-400">
                        <i class="fas fa-flask"></i>
                    </div>
                    <span class="text-xs text-gray-500">Chemicals Analyzed</span>
                </div>
                <div class="text-3xl font-bold"><%= stats ? stats.totalChemicals : 0 %></div>
                <div class="text-sm text-gray-400 mt-2">
                    Total chemicals detected
                </div>
            </div>
        </div>

        <!-- Recent Activity -->
        <div class="stat-card rounded-2xl p-6">
            <h2 class="text-xl font-bold mb-6">Recent Scans</h2>
            <div class="space-y-4">
                <% if (stats && stats.recentScans && stats.recentScans.length > 0) { %>
                    <% stats.recentScans.forEach(function(scan) { %>
                        <div class="flex items-center justify-between p-4 bg-gray-900/50 rounded-xl">
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 rounded-lg bg-gray-800 overflow-hidden">
                                    <div class="w-full h-full bg-purple-900/20 flex items-center justify-center text-purple-400">
                                        <i class="fas fa-box"></i>
                                    </div>
                                </div>
                                <div>
                                    <div class="font-bold"><%= scan.productName %></div>
                                    <div class="text-xs text-gray-500"><%= new Date(scan.scannedAt).toLocaleString() %></div>
                                </div>
                            </div>
                            <% if (scan.isSafe) { %>
                                <span class="px-3 py-1 bg-green-900/30 text-green-400 text-xs rounded-full border border-green-900/50">SAFE</span>
                            <% } else { %>
                                <span class="px-3 py-1 bg-red-900/30 text-red-400 text-xs rounded-full border border-red-900/50">WARNING</span>
                            <% } %>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="text-gray-400 text-sm">No recent scans found.</div>
                <% } %>
            </div>
        </div>
        <!-- Health Profile & Preferences -->
        <div class="stat-card rounded-2xl p-6 mt-6">
            <h2 class="text-xl font-bold mb-6 text-purple-400"><i class="fas fa-heartbeat mr-2"></i> Health Profile & Preferences</h2>
            <form id="preferencesForm" class="space-y-6">
                <div>
                    <label class="block text-sm font-medium text-gray-300 mb-2">Allergies (comma separated)</label>
                    <input type="text" id="allergies" placeholder="e.g., Peanuts, Dairy, Shellfish" class="w-full bg-gray-900 border border-gray-700 rounded-lg p-3 text-white focus:outline-none focus:border-purple-500 transition-colors">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-300 mb-2">Dietary Restrictions</label>
                    <input type="text" id="diet" placeholder="e.g., Vegan, Keto, Halal, Gluten-Free" class="w-full bg-gray-900 border border-gray-700 rounded-lg p-3 text-white focus:outline-none focus:border-purple-500 transition-colors">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-300 mb-2">Health Conditions</label>
                    <input type="text" id="conditions" placeholder="e.g., Diabetes, Hypertension" class="w-full bg-gray-900 border border-gray-700 rounded-lg p-3 text-white focus:outline-none focus:border-purple-500 transition-colors">
                </div>
                <button type="submit" id="savePreferencesBtn" class="bg-gradient-to-r from-purple-600 to-green-600 text-white font-bold py-3 px-6 rounded-lg hover:from-purple-500 hover:to-green-500 transition-all flex items-center justify-center w-full md:w-auto gap-2">
                    <i class="fas fa-save"></i> Save Preferences
                </button>
                <div id="preferencesMessage" class="mt-2 text-sm hidden"></div>
            </form>
        </div>


    </main>

    <!-- Footer Decoration -->
    <div class="fixed bottom-0 left-0 w-full h-1 bg-gradient-to-r from-purple-600 to-green-600"></div>

    <!-- Preferences Logic -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const form = document.getElementById('preferencesForm');
            const saveBtn = document.getElementById('savePreferencesBtn');
            const messageDiv = document.getElementById('preferencesMessage');
            
            // Wait for Clerk to be ready
            const initPreferences = async () => {
                if (!window.Clerk || !window.Clerk.user) {
                    setTimeout(initPreferences, 500);
                    return;
                }
                
                const user = window.Clerk.user;
                const metadata = user.publicMetadata || {};
                
                // Populate existing data
                document.getElementById('allergies').value = metadata.allergies || '';
                document.getElementById('diet').value = metadata.diet || '';
                document.getElementById('conditions').value = metadata.conditions || '';
            };

            initPreferences();

            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                saveBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';
                saveBtn.disabled = true;
                
                const data = {
                    allergies: document.getElementById('allergies').value.trim(),
                    diet: document.getElementById('diet').value.trim(),
                    conditions: document.getElementById('conditions').value.trim()
                };

                try {
                    const response = await fetch('/api/user/preferences', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify(data)
                    });

                    if (response.ok) {
                        messageDiv.className = "mt-2 text-sm text-green-400 block";
                        messageDiv.innerText = "Preferences saved successfully! You might need to refresh the page to see changes in your profile object.";
                    } else {
                        throw new Error('Failed to save');
                    }
                } catch (error) {
                    messageDiv.className = "mt-2 text-sm text-red-400 block";
                    messageDiv.innerText = "Error saving preferences. Please try again.";
                } finally {
                    saveBtn.innerHTML = '<i class="fas fa-save"></i> Save Preferences';
                    saveBtn.disabled = false;
                }
            });
        });
    </script>
</body>
</html>
